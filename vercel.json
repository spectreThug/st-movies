{
  "version": 2,
  "builds": [
    { "src": "main.js", "use": "@vercel/node" },
    { "src": "public/**", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "main.js" },
    { "src": "/styles.css", "dest": "public/styles.css" },
    { "src": "/app.js", "dest": "public/app.js" },
    { "src": "/(.*)", "dest": "public/index.html" }
  ]
}
